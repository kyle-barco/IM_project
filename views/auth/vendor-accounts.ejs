<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body class="auth-page">
  <div class="auth-container" style="max-width: 600px;">
    <div class="auth-brand">
      <span class="brand-byte">Byte</span><span class="brand-market">Market</span>
      <p>Vendor Login Credentials</p>
    </div>
    <%- include('../partials/flash') %>
    <div style="padding: 0 0 16px;">
      <a href="/login" style="color: #f5a623; text-decoration: none; font-size: 14px;">&larr; Back to Sign In</a>
    </div>
    <div style="display: flex; flex-direction: column; gap: 8px;">
      <% vendors.forEach(v => { %>
        <div style="display: flex; justify-content: space-between; align-items: center; background: #1a1d27; padding: 12px 16px; border-radius: 8px; border: 1px solid #2a2d35;">
          <div>
            <strong style="color: #f0f0f0;"><%= v.name %></strong>
            <span style="color: #888; font-size: 13px; margin-left: 8px;">[<%= v.stallNumber %>]</span>
          </div>
          <% if (v.user) { %>
            <div style="font-family: 'IBM Plex Mono', monospace; font-size: 13px; text-align: right; line-height: 1.6;">
              <span style="color: #f5a623;"><%= v.user.username %></span>
              <br/>
              <span style="color: #888;">password: </span><span style="color: #aaa;"><%= v.user.username %></span>
            </div>
          <% } else { %>
            <span style="color: #666; font-size: 13px;">No account</span>
          <% } %>
        </div>
      <% }) %>
    </div>
    <p style="text-align: center; margin-top: 16px; color: #888; font-size: 13px;">
      All vendor passwords match their username (e.g. burger-station / burger-station)
    </p>
  </div>
</body>
</html>
