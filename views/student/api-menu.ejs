<!DOCTYPE html>
<html lang="en">

<head><%- include('../partials/head') %></head>

<body>
  <%- include('../partials/navbar') %>

    <main class="api-menu-wrapper">

      <!-- Header + Controls -->
      <div class="api-menu-header">
        <div>
          <h1 class="api-menu-title"><i class="ph ph-fork-knife"></i> Food Menu</h1>
          <p class="api-menu-sub">Browse dishes from around the world</p>
        </div>
        <div class="api-menu-controls">
          <div class="search-wrap">
            <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.35-4.35" />
            </svg>
            <input type="text" id="searchInput" class="search-input" placeholder="Search dishes..."
              autocomplete="off" />
            <button class="search-clear" id="clearSearch" style="display:none"><i class="ph ph-x"></i></button>
          </div>
          <div class="dropdown-wrap" id="dropdownWrap">
            <button class="dropdown-btn" id="dropdownBtn">
              <span id="dropdownLabel">All Categories</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chevron">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
            <ul class="dropdown-list" id="dropdownList">
              <li class="dropdown-item active" data-category="all">All Categories</li>
              <% menu.forEach(({ category })=> { %>
                <li class="dropdown-item" data-category="<%= category %>">
                  <%= category.replace(/-/g, ' ' ) %>
                </li>
                <% }) %>
            </ul>
          </div>
        </div>
      </div>

      <!-- Active filter pill -->
      <div class="filter-status" id="filterStatus" style="display:none">
        <span id="filterLabel"></span>
        <button class="clear-filter" id="clearFilter"><i class="ph ph-x"></i> Clear</button>
      </div>

      <!-- No results -->
      <div class="no-results" id="noResults" style="display:none">
        <p><i class="ph ph-smiley-sad"></i> No dishes found. Try a different search or category.</p>
      </div>

      <!-- Menu Sections -->
      <% menu.forEach(({ category, items })=> { %>
        <section class="menu-section" data-section="<%= category %>">
          <div class="section-heading">
            <h2 class="category-title">
              <%= category.replace(/-/g, ' ' ) %>
            </h2>
            <span class="item-count" data-total="<%= items.length %>">
              <%= items.length %> items
            </span>
          </div>

          <div class="menu-grid">
            <%
              const vendorMap = {
                'burgers':       'Burger Station',
                'pizzas':        'Pizza Corner',
                'best-foods':    'Best Bites',
                'fried-chicken': 'Crispy Chick',
                'drinks':        'Sip & Go',
                'desserts':      'Sweet Spot',
                'ice-cream':     'Chill Zone',
                'sandwiches':    'Sandwich Hub',
                'steaks':        'Grill House',
                'bbqs':          'BBQ Pit',
                'breads':        'The Bakery',
                'chocolates':    'Choco World',
                'porks':         'Pork Palace',
                'sausages':      'Sausage Co.',
              };
              const vendorName = vendorMap[category] || category;
            %>

              <% items.forEach((item, idx)=> { %>
                <% const stock=stockMap && stockMap[item.name] !=null ? stockMap[item.name] : 10; %>
                  <div class="menu-card" data-name="<%= item.name.toLowerCase() %>"
                    data-desc="<%= item.dsc.toLowerCase() %>" data-img="<%= item.img %>" data-itemid="<%= item.id %>"
                    data-rate="<%= item.rate %>">
                    <div class="menu-card-img-wrap">
                      <img src="<%= item.img %>" alt="<%= item.name %>" class="menu-card-img" loading="lazy"
                        onerror="this.src='https://placehold.co/400x300/1a1d27/f5a623?text=No+Image'" />
                    </div>

                    <div class="menu-card-body">
                      <!-- Top row: name + price -->
                      <div class="menu-card-top">
                        <h3 class="menu-card-name">
                          <%= item.name %>
                        </h3>
                        <span class="menu-card-price">₱<%= item.price %></span>
                      </div>

                      <p class="menu-card-desc">
                        <%= item.dsc %>
                      </p>

                      <div class="menu-card-tags">
                        <span class="menu-card-tag vendor-tag">
                          <%= vendorName %>
                        </span>
                      </div>

                      <!-- Stock + rating -->
                      <div class="menu-card-meta">
                        <span class="stock-count">
                          <%= stock %> left
                        </span>
                        <span class="menu-card-rate"><i class="ph ph-star icon-star"></i> <%= item.rate %></span>
                      </div>
                    </div>

                    <!-- Add to Cart footer -->
                    <div class="menu-card-footer">
                      <div class="qty-wrap">
                        <button class="qty-btn" onclick="changeQty(this, -1)">−</button>
                        <input type="number" class="qty-input" value="1" min="1" max="<%= stock %>" readonly />
                        <button class="qty-btn" onclick="changeQty(this, 1)">+</button>
                      </div>
                      <button class="add-cart-btn" onclick="addToCart(this, '<%= item.id %>')"
                        data-stock="<%= stock %>">
                        Add to Cart
                      </button>
                    </div>

                  </div>
                  <% }) %>
          </div>
        </section>
        <% }) %>

    </main>

    <!-- Toast notification -->
    <div class="toast" id="toast"></div>

<!-- Item detail modal -->
<div class="modal-overlay" id="itemModal">
  <div class="modal-content">
    <button class="modal-close" id="modalClose"><i class="ph ph-x"></i></button>
    <div class="modal-scroll">
      <div class="modal-layout">
        <div class="modal-img-wrap">
          <img id="modalImg" src="" alt="" />
        </div>
        <div class="modal-info">
          <div class="modal-header">
            <h2 id="modalName"></h2>
          </div>
          <div class="modal-tags">
            <span class="menu-card-tag vendor-tag" id="modalVendor"></span>
            <span class="menu-card-rate" id="modalRate"></span>
          </div>
          <p class="modal-desc" id="modalDesc"></p>
          <div class="modal-meta">
            <span class="stock-count" id="modalStock"></span>
            <span class="modal-price" id="modalPrice"></span>
          </div>
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <div class="qty-wrap">
        <button class="qty-btn" onclick="modalChangeQty(-1)">−</button>
        <input type="number" class="qty-input" id="modalQty" value="1" min="1" readonly />
        <button class="qty-btn" onclick="modalChangeQty(1)">+</button>
      </div>
      <button class="add-cart-btn" id="modalAddBtn">Add to Cart</button>
    </div>
  </div>
</div>

    <style>
      /* ── Layout ──────────────────────────────────────────── */
      .api-menu-wrapper {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      .api-menu-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.2rem;
        margin-bottom: 1.5rem;
      }

      .api-menu-title {
        font-size: 2rem;
        font-weight: 700;
        color: #ffffff;
        margin: 0 0 .3rem;
      }

  .api-menu-sub {
    color: #8b95a1;
    font-size: .95rem;
    margin: 0;
  }

  .api-menu-title i { margin-right: .5rem; }
  .icon-star { color: #f5a623; }
  .ph { vertical-align: middle; }

      /* ── Controls ────────────────────────────────────────── */
      .api-menu-controls {
        display: flex;
        gap: .75rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .search-wrap {
        position: relative;
        display: flex;
        align-items: center;
      }

      .search-icon {
        position: absolute;
        left: .75rem;
        width: 16px;
        height: 16px;
        color: #8b95a1;
        pointer-events: none;
      }

      .search-input {
        background: #1a1d27;
        border: 1px solid #2a2d35;
        border-radius: 8px;
        color: #ffffff;
        font-size: .9rem;
        padding: .6rem 2.2rem .6rem 2.4rem;
        width: 240px;
        outline: none;
        transition: border-color .2s;
      }

      .search-input::placeholder {
        color: #8b95a1;
      }

      .search-input:focus {
        border-color: #f5a623;
      }

      .search-clear {
        position: absolute;
        right: .6rem;
        background: none;
        border: none;
        color: #8b95a1;
        cursor: pointer;
        font-size: .85rem;
      }

      .search-clear:hover {
        color: #f5a623;
      }

      /* ── Dropdown ────────────────────────────────────────── */
      .dropdown-wrap {
        position: relative;
      }

      .dropdown-btn {
        display: flex;
        align-items: center;
        gap: .5rem;
        background: #1a1d27;
        border: 1px solid #2a2d35;
        border-radius: 8px;
        color: #ffffff;
        font-size: .9rem;
        padding: .6rem 1rem;
        cursor: pointer;
        white-space: nowrap;
        transition: border-color .2s;
      }

      .dropdown-btn:hover,
      .dropdown-wrap.open .dropdown-btn {
        border-color: #f5a623;
      }

      .chevron {
        width: 16px;
        height: 16px;
        transition: transform .2s;
      }

      .dropdown-wrap.open .chevron {
        transform: rotate(180deg);
      }

      .dropdown-list {
        display: none;
        position: absolute;
        top: calc(100% + 6px);
        right: 0;
        background: #1a1d27;
        border: 1px solid #2a2d35;
        border-radius: 10px;
        list-style: none;
        margin: 0;
        padding: .4rem 0;
        min-width: 180px;
        z-index: 100;
        max-height: 300px;
        overflow-y: auto;
        box-shadow: 0 8px 24px rgba(0, 0, 0, .4);
      }

      .dropdown-wrap.open .dropdown-list {
        display: block;
      }

      .dropdown-item {
        padding: .55rem 1rem;
        font-size: .88rem;
        color: #c5ccd6;
        cursor: pointer;
        text-transform: capitalize;
        transition: background .15s, color .15s;
      }

      .dropdown-item:hover {
        background: #12141c;
        color: #ffffff;
      }

      .dropdown-item.active {
        color: #f5a623;
        font-weight: 600;
      }

      /* ── Filter pill ─────────────────────────────────────── */
      .filter-status {
        display: flex;
        align-items: center;
        gap: .6rem;
        margin-bottom: 1.2rem;
        font-size: .85rem;
        color: #8b95a1;
      }

      #filterLabel {
        background: #1a1d27;
        border: 1px solid #f5a623;
        color: #f5a623;
        border-radius: 999px;
        padding: .2rem .8rem;
        font-size: .8rem;
      }

      .clear-filter {
        background: none;
        border: none;
        color: #8b95a1;
        cursor: pointer;
        font-size: .8rem;
      }

      .clear-filter:hover {
        color: #f5a623;
      }

      /* ── No results ──────────────────────────────────────── */
      .no-results {
        text-align: center;
        padding: 4rem 0;
        color: #8b95a1;
      }

      /* ── Section ─────────────────────────────────────────── */
      .menu-section {
        margin-bottom: 3rem;
      }

      .section-heading {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.2rem;
        border-bottom: 1px solid #2a2d35;
        padding-bottom: .7rem;
      }

      .category-title {
        font-size: 1.2rem;
        font-weight: 600;
        color: #ffffff;
        text-transform: capitalize;
        margin: 0;
      }

      .item-count {
        font-size: .75rem;
        color: #8b95a1;
        background: #1e2028;
        padding: .2rem .6rem;
        border-radius: 999px;
        border: 1px solid #2a2d35;
      }

      /* ── Grid ────────────────────────────────────────────── */
      .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 1.2rem;
      }

      /* ── Card ────────────────────────────────────────────── */
      .menu-card {
        background: #1a1d27;
        border: 1px solid #2a2d35;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        transition: transform .2s ease, border-color .2s ease;
      }

      .menu-card:hover {
        transform: translateY(-3px);
        border-color: #f5a623;
      }

      .menu-card-img-wrap {
        width: 100%;
        height: 150px;
        overflow: hidden;
        background: #12141c;
      }

      .menu-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform .3s ease;
      }

      .menu-card:hover .menu-card-img {
        transform: scale(1.05);
      }

      /* ── Card body ───────────────────────────────────────── */
      .menu-card-body {
        padding: .85rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: .45rem;
      }

      /* name + price on same row */
      .menu-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .5rem;
      }

      .menu-card-name {
        font-size: .92rem;
        font-weight: 600;
        color: #ffffff;
        margin: 0;
        line-height: 1.3;
        flex: 1;
      }

      .menu-card-price {
        font-size: .95rem;
        font-weight: 700;
        color: #f5a623;
        white-space: nowrap;
      }

      .menu-card-desc {
        font-size: .77rem;
        color: #8b95a1;
        margin: 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      /* ── Tags ────────────────────────────────────────────── */
      .menu-card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
      }

      .menu-card-tag {
        display: inline-block;
        font-size: .68rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
        border-radius: 4px;
        padding: .15rem .5rem;
      }

      .vendor-tag {
        color: #f5a623;
        background: rgba(245, 166, 35, .1);
        border: 1px solid rgba(245, 166, 35, .25);
      }

      /* ── Meta row (stock + rating) ───────────────────────── */
      .menu-card-meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
      }

      .stock-count {
        font-size: .75rem;
        font-family: monospace;
        color: #8b95a1;
      }

      .menu-card-rate {
        font-size: .78rem;
        color: #8b95a1;
      }

      /* ── Card footer: qty + button ───────────────────────── */
      .menu-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: .5rem;
        padding: .65rem .85rem;
        border-top: 1px solid #2a2d35;
        background: #12141c;
      }

      /* Quantity control */
      .qty-wrap {
        display: flex;
        align-items: center;
        background: #1a1d27;
        border: 1px solid #2a2d35;
        border-radius: 6px;
        overflow: hidden;
      }

      .qty-btn {
        background: none;
        border: none;
        color: #ffffff;
        font-size: 1.1rem;
        width: 28px;
        height: 32px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .15s;
        line-height: 1;
      }

      .qty-btn:hover {
        background: #2a2d35;
        color: #f5a623;
      }

      .qty-input {
        width: 32px;
        text-align: center;
        background: none;
        border: none;
        color: #ffffff;
        font-size: .88rem;
        -moz-appearance: textfield;
        outline: none;
      }

      .qty-input::-webkit-inner-spin-button,
      .qty-input::-webkit-outer-spin-button {
        -webkit-appearance: none;
      }

      /* Add to Cart button */
      .add-cart-btn {
        background: #f5a623;
        color: #0f1117;
        21 border: none;
        border-radius: 6px;
        font-size: .78rem;
        font-weight: 700;
        padding: .45rem .75rem;
        cursor: pointer;
        white-space: nowrap;
        transition: background .2s, transform .1s;
        flex-shrink: 0;
      }

      .add-cart-btn:hover {
        background: #e09510;
      }

      .add-cart-btn:active {
        transform: scale(.96);
      }

      .add-cart-btn:disabled {
        background: #2a2d35;
        color: #8b95a1;
        cursor: not-allowed;
      }

      /* ── Modal ───────────────────────────────────────────── */
      .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, .7);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }

      .modal-overlay.open {
        display: flex;
      }

  .modal-content {
    background: #1a1d27;
    border: 1px solid #2a2d35;
    border-radius: 16px;
    max-width: 700px;
    width: 100%;
    max-height: 90vh;
    display: flex;
    flex-direction: column;
    position: relative;
    box-shadow: 0 16px 48px rgba(0,0,0,.5);
  }

  .modal-scroll {
    overflow-y: auto;
    flex: 1;
  }

  .modal-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid #2a2d35;
    background: #12141c;
    border-radius: 0 0 16px 16px;
    flex-shrink: 0;
  }

      .modal-close {
        position: absolute;
        top: .75rem;
        right: .75rem;
        background: #12141c;
        border: 1px solid #2a2d35;
        color: #8b95a1;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        font-size: 1rem;
        cursor: pointer;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s, color .2s;
      }

      .modal-close:hover {
        background: #2a2d35;
        color: #fff;
      }

      .modal-layout {
        display: flex;
        flex-direction: column;
      }

      .modal-img-wrap {
        width: 100%;
        max-height: 320px;
        overflow: hidden;
        border-radius: 16px 16px 0 0;
        background: #12141c;
      }

      .modal-img-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

  .modal-info {
    padding: 1.5rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

      .modal-header {
        display: flex;
        align-items: flex-start;
      }

      #modalName {
        font-size: 1.4rem;
        font-weight: 700;
        color: #fff;
        margin: 0;
      }

      .modal-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #f5a623;
        white-space: nowrap;
      }

      .modal-tags {
        display: flex;
        gap: .5rem;
        align-items: center;
      }

      .modal-desc {
        font-size: .9rem;
        color: #8b95a1;
        line-height: 1.6;
        margin: 0;
      }

      .modal-meta {
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }

      @media (min-width: 600px) {
        .modal-layout {
          flex-direction: row;
        }

        .modal-img-wrap {
          max-width: 280px;
          max-height: none;
          border-radius: 16px 0 0 16px;
        }

        .modal-img-wrap img {
          height: 100%;
          min-height: 280px;
        }

        .modal-info {
          flex: 1;
        }
      }

      /* ── Toast ───────────────────────────────────────────── */
      .toast {
        position: fixed;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        background: #1a1d27;
        border: 1px solid #f5a623;
        color: #ffffff;
        padding: .7rem 1.4rem;
        border-radius: 8px;
        font-size: .88rem;
        opacity: 0;
        pointer-events: none;
        transition: opacity .25s, transform .25s;
        z-index: 999;
        white-space: nowrap;
      }

      .toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      /* ── Responsive ──────────────────────────────────────── */
      @media (max-width: 600px) {
        .api-menu-header {
          flex-direction: column;
        }

        .api-menu-controls {
          width: 100%;
        }

        .search-input {
          width: 100%;
        }

        .menu-grid {
          grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        }

        .menu-card-img-wrap {
          height: 120px;
        }
      }
    </style>

    <script>
      /* ── Item detail modal ───────────────────────────────── */
      const modal = document.getElementById('itemModal');
      const modalName = document.getElementById('modalName');
      const modalImg = document.getElementById('modalImg');
      const modalPrice = document.getElementById('modalPrice');
      const modalDesc = document.getElementById('modalDesc');
      const modalStock = document.getElementById('modalStock');
      const modalRate = document.getElementById('modalRate');
      const modalVendor = document.getElementById('modalVendor');
      const modalQty = document.getElementById('modalQty');
      const modalAddBtn = document.getElementById('modalAddBtn');
      let activeCard = null;

      document.querySelectorAll('.menu-card').forEach(card => {
        card.addEventListener('click', e => {
          if (e.target.closest('.menu-card-footer')) return;
          activeCard = card;
          const img = card.dataset.img;
          const name = card.querySelector('.menu-card-name').textContent;
          const price = card.querySelector('.menu-card-price').textContent;
          const desc = card.querySelector('.menu-card-desc').textContent;
          const vendor = card.querySelector('.vendor-tag').textContent;
          const rate = card.dataset.rate;
          const stockEl = card.querySelector('.stock-count');
          const stockText = stockEl ? stockEl.textContent : '10 left';

          modalImg.src = img;
          modalImg.alt = name;
          modalName.textContent = name;
          modalPrice.textContent = price;
          modalDesc.textContent = desc;
          modalVendor.textContent = vendor;
          modalRate.innerHTML = '<i class="ph ph-star icon-star"></i> ' + rate;
          modalStock.textContent = stockText;
          modalQty.value = '1';
          modal.classList.add('open');
        });
      });

      function closeModal() {
        modal.classList.remove('open');
        activeCard = null;
      }

      document.getElementById('modalClose').addEventListener('click', closeModal);
      modal.addEventListener('click', e => {if (e.target === modal) closeModal();});
      document.addEventListener('keydown', e => {if (e.key === 'Escape') closeModal();});

      function modalChangeQty(delta) {
        const card = activeCard;
        if (!card) return;
        const totalStock = parseInt(card.querySelector('.add-cart-btn').dataset.stock);
        let val = parseInt(modalQty.value) + delta;
        val = Math.max(1, Math.min(totalStock, val));
        modalQty.value = val;
        const remaining = totalStock - val;
        modalStock.textContent = remaining + ' left';
      }

      modalAddBtn.addEventListener('click', () => {
        if (!activeCard) return;
        const btn = activeCard.querySelector('.add-cart-btn');
        const itemId = activeCard.dataset.itemid;
        modalQty.value = parseInt(modalQty.value) || 1;
        // Override the card's qty input with modal's value, then click
        const cardQty = activeCard.querySelector('.qty-input');
        cardQty.value = modalQty.value;
        btn.click();
        activeCard = null;
        closeModal();
      });

      /* ── Quantity controls ───────────────────────────────── */
      function changeQty(btn, delta) {
        const wrap = btn.closest('.qty-wrap');
        const input = wrap.querySelector('.qty-input');
        const card = btn.closest('.menu-card');
        const totalStock = parseInt(card.querySelector('.add-cart-btn').dataset.stock);
        let val = parseInt(input.value) + delta;
        val = Math.max(1, Math.min(totalStock, val));
        input.value = val;

        // Update the "X left" indicator to reflect the selection
        const remaining = totalStock - val;
        card.querySelector('.stock-count').textContent = remaining + ' left';
      }

      /* ── Add to cart ─────────────────────────────────────── */
      function addToCart(btn, itemId) {
        const card = btn.closest('.menu-card');
        const qtyEl = card.querySelector('.qty-input');
        const qty = qtyEl.value;
        const name = card.querySelector('.menu-card-name').textContent;
        const price = card.querySelector('.menu-card-price').textContent.replace('₱', '');
        const vendor = card.querySelector('.vendor-tag').textContent;
        const desc = card.querySelector('.menu-card-desc').textContent;
        const section = card.closest('.menu-section');
        const category = section ? section.dataset.section : '';

        const params = new URLSearchParams();
        params.set('itemId', itemId);
        params.set('quantity', qty);
        params.set('apiItem', 'true');
        params.set('name', name);
        params.set('price', price);
        params.set('vendorName', vendor);
        params.set('category', category);
        params.set('description', desc);

        fetch('/student/cart/add', {
          method: 'POST',
          headers: {'Content-Type': 'application/x-www-form-urlencoded'},
          body: params.toString(),
        })
          .then(res => {
            if (res.ok || res.redirected) {
              showToast(`<i class="ph ph-check"></i> ${name} added to cart`);
              updateCartBadge();
              // Update stock indicator in real time
              const stockEl = card.querySelector('.stock-count');
              const added = parseInt(qty) || 1;
              let remaining = parseInt(card.querySelector('.add-cart-btn').dataset.stock) - added;
              if (remaining < 0) remaining = 0;
              card.querySelector('.add-cart-btn').dataset.stock = remaining;
              stockEl.textContent = remaining + ' left';
              if (remaining === 0) {
                btn.disabled = true;
                btn.textContent = 'Out of stock';
              }
              qtyEl.value = 1;
              qtyEl.max = remaining;
            } else {
              showToast('<i class="ph ph-warning-circle"></i> Could not add item — check stock');
            }
          })
          .catch(() => showToast('<i class="ph ph-warning-circle"></i> Network error, please try again'));
      }

      /* ── Cart badge updater ──────────────────────────────── */
      function updateCartBadge() {
        fetch('/student/cart/count')
          .then(r => r.json())
          .then(data => {
            const badge = document.getElementById('cart-badge');
            if (badge) {
              badge.textContent = data.count;
              badge.style.display = data.count > 0 ? 'inline-block' : 'none';
            }
          })
          .catch(() => { });
      }

      /* ── Toast helper ────────────────────────────────────── */
      let toastTimer;
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.innerHTML = msg;
        t.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => t.classList.remove('show'), 2500);
      }

      /* ── Dropdown ────────────────────────────────────────── */
      const dropdownWrap = document.getElementById('dropdownWrap');
      const dropdownBtn = document.getElementById('dropdownBtn');
      const dropdownList = document.getElementById('dropdownList');
      const dropdownLabel = document.getElementById('dropdownLabel');
      const filterStatus = document.getElementById('filterStatus');
      const filterLabel = document.getElementById('filterLabel');
      const clearFilter = document.getElementById('clearFilter');
      const searchInput = document.getElementById('searchInput');
      const clearSearch = document.getElementById('clearSearch');
      const noResults = document.getElementById('noResults');

      let activeCategory = 'all';
      let searchQuery = '';

      dropdownBtn.addEventListener('click', () => dropdownWrap.classList.toggle('open'));
      document.addEventListener('click', e => {
        if (!dropdownWrap.contains(e.target)) dropdownWrap.classList.remove('open');
      });

      dropdownList.addEventListener('click', e => {
        const item = e.target.closest('.dropdown-item');
        if (!item) return;
        activeCategory = item.dataset.category;
        dropdownLabel.textContent = item.textContent.trim();
        document.querySelectorAll('.dropdown-item').forEach(i => i.classList.remove('active'));
        item.classList.add('active');
        dropdownWrap.classList.remove('open');
        applyFilters();
      });

      searchInput.addEventListener('input', () => {
        searchQuery = searchInput.value.trim().toLowerCase();
        clearSearch.style.display = searchQuery ? 'block' : 'none';
        applyFilters();
      });

      clearSearch.addEventListener('click', () => {
        searchInput.value = '';
        searchQuery = '';
        clearSearch.style.display = 'none';
        applyFilters();
      });

      clearFilter.addEventListener('click', () => {
        activeCategory = 'all';
        dropdownLabel.textContent = 'All Categories';
        document.querySelectorAll('.dropdown-item').forEach(i => i.classList.remove('active'));
        document.querySelector('.dropdown-item[data-category="all"]').classList.add('active');
        applyFilters();
      });

      /* ── Filter logic ────────────────────────────────────── */
      function applyFilters() {
        const sections = document.querySelectorAll('.menu-section');
        let totalVisible = 0;
        sections.forEach(section => {
          const cat = section.dataset.section;

          if (activeCategory !== 'all' && cat !== activeCategory) {
            section.style.display = 'none';
            return;
          }

          section.style.display = '';
          const cards = section.querySelectorAll('.menu-card');
          let visible = 0;

          cards.forEach(card => {
            const match = !searchQuery
              || card.dataset.name.includes(searchQuery)
              || card.dataset.desc.includes(searchQuery);
            card.style.display = match ? '' : 'none';
            if (match) visible++;
          });

          section.querySelector('.item-count').textContent =
            `${visible} item${visible !== 1 ? 's' : ''}`;

          if (visible === 0) section.style.display = 'none';
          totalVisible += visible;
        });

        const hasFilter = activeCategory !== 'all';
        filterStatus.style.display = hasFilter ? 'flex' : 'none';
        if (hasFilter) filterLabel.textContent = activeCategory.replace(/-/g, ' ');

        noResults.style.display = totalVisible === 0 ? 'block' : 'none';
      }
    </script>

</body>

