<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container">
    <div class="page-header">
      <h1>Your Cart</h1>
    </div>
    <%- include('../partials/flash') %>

    <% if (!cart || cart.length === 0) { %>
      <div class="empty-cart">
        <p>Your cart is empty.</p>
        <a href="/student/menu" class="btn-primary">Browse the food court</a>
      </div>
    <% } else { %>
      <% 
        // Group by vendor
        const grouped = {};
        cart.forEach(item => {
          if (!grouped[item.vendorName]) grouped[item.vendorName] = [];
          grouped[item.vendorName].push(item);
        });
        const total = cart.reduce((s, c) => s + c.price * c.quantity, 0);
      %>
      <div class="cart-layout">
        <div class="cart-items">
          <% Object.entries(grouped).forEach(([vendorName, items]) => { %>
          <div class="cart-vendor-group">
            <h3 class="cart-vendor-label"><%= vendorName %></h3>
            <% items.forEach(item => { %>
            <div class="cart-item">
              <div class="cart-item-info">
                <span class="cart-item-name"><%= item.name %></span>
                <span class="cart-item-qty">× <%= item.quantity %></span>
              </div>
              <div class="cart-item-right">
                <span class="cart-item-price">₱<%= (item.price * item.quantity).toFixed(2) %></span>
                <form action="/student/cart/remove" method="POST" style="display:inline">
                  <input type="hidden" name="itemId" value="<%= item.itemId %>" />
                  <button type="submit" class="btn-remove">Remove</button>
                </form>
              </div>
            </div>
            <% }) %>
          </div>
          <% }) %>
        </div>

        <div class="cart-summary">
          <h3>Order Summary</h3>
          <div class="summary-row">
            <span>Items (<%= cart.length %>)</span>
            <span>₱<%= total.toFixed(2) %></span>
          </div>
          <div class="summary-row summary-total">
            <span>Total</span>
            <span>₱<%= total.toFixed(2) %></span>
          </div>
          <form action="/student/checkout" method="POST">
            <button type="submit" class="btn-primary btn-full btn-checkout">Place Order</button>
          </form>
          <a href="/student/menu" class="btn-ghost btn-full" style="margin-top:0.5rem;display:block;text-align:center">Continue browsing</a>
        </div>
      </div>
    <% } %>
  </main>
</body>
</html>
