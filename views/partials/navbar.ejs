<nav class="navbar">
  <a class="navbar-brand" href="/">
    <span class="brand-byte">Byte</span><span class="brand-market">Market</span>
  </a>
  <div class="navbar-links">
    <% if (user) { %>
      <% if (user.role === 'STUDENT') { %>
        <a href="/student/api-menu">Menu</a>
        <a href="/student/cart" class="nav-cart">
          Cart
          <span class="cart-badge" id="cart-badge" style="display:<%= cartCount > 0 ? 'inline-block' : 'none' %>"><%= cartCount %></span>
        </a>
        <a href="/student/orders" class="nav-cart">
          My Orders
          <span class="cart-badge" id="orders-badge" style="display:none">0</span>
        </a>
      <% } else if (user.role === 'VENDOR') { %>
        <a href="/vendor/dashboard" class="nav-cart">
          Queue
          <span class="cart-badge" id="queue-badge" style="display:none">0</span>
        </a>
        <a href="/vendor/menu">My Menu</a>
        <a href="/vendor/sales">Sales</a>
        <a href="/student/api-menu">Menu</a>
        <a href="/student/cart" class="nav-cart">
          Cart
          <span class="cart-badge" id="cart-badge" style="display:<%= cartCount > 0 ? 'inline-block' : 'none' %>"><%= cartCount %></span>
        </a>
        <a href="/student/orders" class="nav-cart">
          My Orders
          <span class="cart-badge" id="orders-badge" style="display:none">0</span>
        </a>
      <% } else if (user.role === 'ADMIN') { %>
        <a href="/admin/dashboard">Dashboard</a>
        <a href="/admin/orders">Orders</a>
        <a href="/admin/menu">Menu</a>
        <a href="/admin/vendors">Vendors</a>
        <a href="/admin/users">Users</a>
      <% } %>
      <span class="nav-user"><%= user.username %> · <%= user.role %></span>
      <form action="/logout" method="POST" style="display:inline">
        <button type="submit" class="btn-ghost">Sign out</button>
      </form>
    <% } else { %>
      <a href="/login">Sign In</a>
    <% } %>
  </div>
</nav>

<% if (user) { %>
<script>
  (function() {
    function poll(url, id) {
      if (!document.getElementById(id)) return;
      function update() {
        fetch(url)
          .then(r => r.json())
          .then(d => {
            const badge = document.getElementById(id);
            if (badge) {
              badge.textContent = d.count;
              badge.style.display = d.count > 0 ? 'inline-block' : 'none';
            }
          })
          .catch(() => {});
      }
      update();
      setInterval(update, 4000);
      document.addEventListener('visibilitychange', () => { if (!document.hidden) update(); });
    }
    <% if (user.role === 'STUDENT' || user.role === 'VENDOR') { %>
      poll('/student/orders/count', 'orders-badge');
      poll('/student/cart/count', 'cart-badge');
    <% } %>
    <% if (user.role === 'VENDOR') { %>
      poll('/vendor/orders/count', 'queue-badge');
    <% } %>
  })();
</script>
<% } %>
