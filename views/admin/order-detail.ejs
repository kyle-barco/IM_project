<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
  <%- include('../partials/navbar') %>
  <main class="container container-narrow">
    <div class="page-header">
      <h1>Order #<%= order.id %></h1>
      <a href="/admin/orders" class="btn-ghost">Back</a>
    </div>
    <%- include('../partials/flash') %>

    <div class="receipt">
      <div class="receipt-header">
        <span class="status-badge status-<%= order.status.toLowerCase() %>"><%= order.status %></span>
      </div>

      <div class="receipt-meta">
        <div><label>Order</label><span>#<%= order.id %></span></div>
        <div><label>Student</label><span><%= order.student.username %></span></div>
        <div><label>Date</label><span><%= new Date(order.createdAt).toLocaleString() %></span></div>
      </div>

      <%
        const byVendor = {};
        order.orderLines.forEach(line => {
          const vname = line.menuItem.vendor.name;
          if (!byVendor[vname]) byVendor[vname] = [];
          byVendor[vname].push(line);
        });
      %>

      <% Object.entries(byVendor).forEach(([vname, lines]) => { %>
      <div class="receipt-vendor">
        <h4 class="receipt-vendor-name"><%= vname %></h4>
        <% lines.forEach(line => { %>
        <div class="receipt-line">
          <span><%= line.quantity %>× <%= line.menuItem.name %></span>
          <span>₱<%= (parseFloat(line.unitPrice) * line.quantity).toFixed(2) %></span>
        </div>
        <% }) %>
      </div>
      <% }) %>

      <div class="receipt-total">
        <span>Total</span>
        <span>₱<%= parseFloat(order.totalPrice).toFixed(2) %></span>
      </div>

      <div class="receipt-actions" style="margin-top:1.5rem;">
        <form action="/admin/orders/<%= order.id %>/status" method="POST" style="display:flex;gap:.5rem;flex-wrap:wrap;">
          <% if (['PENDING','PREPARING','READY'].includes(order.status)) { %>
            <% if (order.status === 'PENDING') { %>
              <button name="status" value="PREPARING" class="btn-primary btn-sm">Start Preparing</button>
            <% } %>
            <% if (order.status === 'PREPARING') { %>
              <button name="status" value="READY" class="btn-primary btn-sm">Mark Ready</button>
            <% } %>
            <% if (order.status === 'READY') { %>
              <button name="status" value="COMPLETED" class="btn-success btn-sm">Complete</button>
            <% } %>
            <button name="status" value="CANCELLED" class="btn-danger btn-sm">Cancel Order</button>
          <% } %>
        </form>
      </div>
    </div>
  </main>
</body>
</html>
